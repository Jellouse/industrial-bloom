{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/industrialbloom", "destination": "/" },
    { "source": "/industrialbloom/", "destination": "/" },
    { "source": "/industrialbloom/api/:path*", "destination": "/api/:path*" },
    { "source": "/industrialbloom/:path*", "destination": "/:path*" }
  ]
}
